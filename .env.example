# ──────────────────────────────────────────────────────────────
# Captionist — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or any service-account JSON to git.
# ──────────────────────────────────────────────────────────────

# ── Firebase (client / public) ────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (server) ───────────────────────────────────
# Provide ONE of the three options below. The loader auto-detects.
#
# Option A — single-line JSON (recommended for Vercel):
#   paste the entire service-account JSON on one line, wrapped in single quotes.
FIREBASE_SERVICE_ACCOUNT=

# Option B — path to a service-account file (good for local dev):
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Option C — three split vars (escape newlines in the private key as \n):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Storage bucket used by the Admin SDK (usually <project-id>.appspot.com)
FIREBASE_STORAGE_BUCKET=

# ── MSG91 (OTP auth) ──────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=

# ── OpenAI (Whisper transcription) ────────────────────────────
OPENAI_API_KEY=

# ── Razorpay (payments) ───────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Admin bootstrap ───────────────────────────────────────────
# Comma-separated list of emails that should be granted the admin role
# automatically the first time they sign in.
ADMIN_EMAILS=you@example.com
